# ─── BC Consultoria — Variáveis de Ambiente ───────────────────────────────────
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite o arquivo .env.local no repositório.

# URL pública do site (sem barra final)
NEXT_PUBLIC_SITE_URL=https://businesscenterconsult.com.br

# Número do WhatsApp para contato (somente dígitos, com DDI)
NEXT_PUBLIC_WHATSAPP_NUMBER=5511913535562

# E-mail de contato principal
NEXT_PUBLIC_EMAIL_CONTACT=contato@businesscenterconsult.com.br

# Google Analytics (opcional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Ambiente (development | production)
NODE_ENV=development
